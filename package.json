{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Gestor de tareas local",
  "main": "main/main.js",
  "scripts": {
    "start": "concurrently \"npm run dev:renderer\" \"wait-on http://127.0.0.1:42879 && electron .\"",
    "dev:renderer": "cd renderer && npm run dev",
    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "28.3.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.taskflow.app",
    "productName": "TaskFlow",
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "preload.js"
    ],
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
